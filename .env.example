
### NGINX
SERVER_NAME="example.com www.example.com"
SSL_CERT="/etc/nginx/ssl/example.com+1.pem"
SSL_KEY="/etc/nginx/ssl/example.com+1-key.pem"

### SERVER
# PORT=3000
# SERVER_PORT=4000
# NEXT_PUBLIC_APP_URL="https://example.com"

### DATABASE
# USE_PROD_DATABASE=1
DATABASE_FILE_NAME=file:.local.db
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app"

### BETTER_AUTH
BETTER_AUTH_SECRET="<better-auth-secret>"
BETTER_AUTH_URL="http://localhost:3000/api/auth"
BETTER_AUTH_TRUSTED_ORIGINS=["http://localhost:3000","https://example.com","https://www.example.com"]
GOOGLE_CLIENT_ID="<google-client-id>"
GOOGLE_CLIENT_SECRET="<google-client-secret>"
