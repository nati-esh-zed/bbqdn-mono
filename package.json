{
  "name": "BBQDN",
  "type": "module",
  "module": "index.ts",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "app/*",
    "package/*"
  ],
  "scripts": {
    "dev": "bun --env-file=.env turbo run dev",
    "build": "bun --env-file=.env turbo run build",
    "start": "bun --env-file=.env turbo run start",
    "lint": "turbo run lint --continue",
    "format": "turbo run format",
    "db:migrate": "bun --env-file=.env turbo run migrate",
    "db:migrate:prod": "bun --env-file=.env turbo run migrate:prod",
    "db:studio": "bun --env-file=.env turbo run studio",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:reload": "pm2 reload ecosystem.config.cjs",
    "pm2:status": "pm2 status"
  },
  "devDependencies": {
    "@app/frontend": "workspace:*",
    "@app/logger": "workspace:*",
    "@app/server": "workspace:*",
    "@types/bun": "latest",
    "turbo": "^2.9.18"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@bepalo/query": "^2.3.12",
    "arktype": "^2.2.1"
  }
}
